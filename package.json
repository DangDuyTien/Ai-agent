{
  "name": "general-ai-agent-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo -p 3100",
    "dev:clean": "node scripts/clean-next.mjs && next dev --turbo -p 3100",
    "clean": "node scripts/clean-next.mjs",
    "build": "next build",
    "build:clean": "node scripts/clean-next.mjs && next build",
    "extension:check": "node --check extensions/vscode/src/extension.js",
    "extension:dev": "code --extensionDevelopmentPath=extensions/vscode .",
    "typecheck": "tsc --noEmit",
    "test:integration": "node --test tests/integration.agent-flow.test.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
